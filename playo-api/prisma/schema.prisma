generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  googleId       String   @unique
  email          String   @unique
  name           String
  avatar         String?
  favoriteSports Sport[]              // saved sport preferences
  homeArea       String?              // e.g. "Indiranagar"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  games       Game[]            @relation("GameHost")
  memberships GameParticipant[]
}

model Game {
  id          String      @id @default(uuid())
  title       String
  sport       Sport
  venue       String
  // ── Location fields ──────────────────────────────
  lat         Float?              // latitude
  lng         Float?              // longitude
  placeId     String?             // Google Place ID
  areaTags    String[]            // ["Indiranagar", "East Bengaluru"]
  // ── Game config ──────────────────────────────────
  scheduledAt DateTime
  maxSlots    Int
  skillLevel  SkillLevel  @default(ALL)
  hostId      String
  status      GameStatus  @default(OPEN)
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  host         User              @relation("GameHost", fields: [hostId], references: [id])
  participants GameParticipant[]

  // Index for geo queries and common filters
  @@index([scheduledAt])
  @@index([sport])
  @@index([status])
  @@index([lat, lng])
}

model GameParticipant {
  id       String            @id @default(uuid())
  gameId   String
  userId   String
  status   ParticipantStatus @default(CONFIRMED)
  joinedAt DateTime          @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([gameId, userId])
}

enum Sport {
  CRICKET
  FOOTBALL
  BADMINTON
  TENNIS
  BASKETBALL
  PICKLEBALL
  OTHER
}

enum SkillLevel {
  ALL           // open to everyone
  BEGINNER
  INTERMEDIATE
  PRO
}

enum GameStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum ParticipantStatus {
  CONFIRMED
  WAITLISTED
  CANCELLED
}
